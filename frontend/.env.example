# Example environment file for frontend deployment
# Copy this to .env and update the backend URL / OAuth client IDs for your app.
VITE_API_URL=https://kalpdrushti.onrender.com

# Google OAuth client ID from Google Cloud Console.
# Add the exact local origin you use, such as http://localhost:5173 or http://127.0.0.1:5173,
# plus your production domain to the OAuth client's authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Apple Sign in requires an Apple Developer Services ID and a registered HTTPS redirect URI.
# Apple does not accept localhost redirect URIs.
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=https://your-domain.com/auth
