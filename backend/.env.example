# LLM configuration
LLM_PROVIDER="groq"
GROQ_API_KEY="your-groq-api-key-here"
LLM_MODEL="llama-3.3-70b-versatile"

# Image generation configuration
# Default is free/no-key Pollinations. For higher quality, set IMAGE_PROVIDER="openai"
# and provide OPENAI_IMAGE_API_KEY.
IMAGE_PROVIDER="pollinations"
IMAGE_MODEL="flux"
IMAGE_QUALITY="high"
IMAGE_MAX_RETRIES="6"
POLLINATIONS_QUALITY="hd"
POLLINATIONS_SAFE="true"
POLLINATIONS_NOFEED="true"
POLLINATIONS_SEED=""
POLLINATIONS_MAX_CONCURRENCY="1"
POLLINATIONS_REQUEST_DELAY_SECONDS="3.5"
IMAGE_PROMPT_MAX_CHARS="1400"
# Optional: lower request dimensions reduce public endpoint throttling.
# Final images are still normalized to the selected video aspect ratio.
POLLINATIONS_WIDTH=""
POLLINATIONS_HEIGHT=""
NEGATIVE_IMAGE_PROMPT="low quality, blurry, soft focus, pixelated, noisy, jpeg artifacts, warped geometry, bad anatomy, distorted face, extra fingers, missing fingers, deformed hands, duplicated people, messy composition, unreadable text, gibberish letters, watermark, logo, signature, cartoon, anime, plastic CGI, oversaturated colors, flat lighting"
OPENAI_IMAGE_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1.5"

# Stripe payment configuration
# Use test-mode keys while developing. Price IDs are optional; if omitted,
# the backend creates monthly subscription line items from the plan amounts.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_STUDIO_PRICE_ID=""
FRONTEND_URL="http://localhost:5173"

# Final MP4 quality
VIDEO_FPS="30"
VIDEO_PRESET="medium"
VIDEO_BITRATE="12M"
VIDEO_AUDIO_BITRATE="192k"

# Background music
# auto = use a matching file from media/audio/bg_music if available, otherwise synthesize a mood-aware instrumental bed.
# files = only use files from media/audio/bg_music. Name files like emotional_piano.mp3 or excited_tech.mp3 for mood matching.
# procedural = always synthesize mood-aware instrumental music.
# off = disable background music.
BACKGROUND_MUSIC_ENABLED="true"
BACKGROUND_MUSIC_SOURCE="auto"
BACKGROUND_MUSIC_VOLUME="0.11"
BACKGROUND_MUSIC_SYNTH_FPS="44100"
